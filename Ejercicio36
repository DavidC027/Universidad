using System;

class Program
{
    static void Main()
    {
        int day = 4;

        switch (day)
        {
            case 1:
                Console.WriteLine("Hoy es Lunes");
                break;

            case 2:
                Console.WriteLine("Hoy es Martes");
                break;

            case 3:
                Console.WriteLine("Hoy es Miércoles");
                break;

            case 4:
                Console.WriteLine("Hoy es Jueves");
                break;

            default:
                Console.WriteLine("Fin de semana");
                break;
        }
    }
}
